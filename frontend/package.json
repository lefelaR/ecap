{
  "name": "ecap",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "preinstall": "node -e \"const major=+process.versions.node.split('.')[0]; if(major<24){console.error('\\nECAP frontend requires Node 24+. Run: cd frontend && nvm use && npm install\\n'); process.exit(1)}\"",
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/eslint/bin/eslint.js ."
  },
  "dependencies": {
    "amazon-cognito-identity-js": "^6.3.16",
    "aws-jwt-verify": "^5.2.1",
    "axios": "^1.17.0",
    "bootstrap": "5.3.8",
    "formik": "^2.4.9",
    "mapbox-gl": "^3.24.0",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "20.17.57",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "typescript": "5.8.3"
  }
}
