{
    "version": 8,
    "name": "South Africa - Provinces and Wards",
    "metadata": {
      "mapbox:autocomposite": true,
      "mapbox:type": "default"
    },
    "center": [24.5, -29.0],
    "zoom": 5,
    "bearing": 0,
    "pitch": 0,
    "sources": {
      "mapbox-streets": {
        "type": "vector",
        "url": "mapbox://mapbox.mapbox-streets-v8"
      },
      "boundaries-adm1": {
        "type": "vector",
        "url": "mapbox://mapbox.boundaries-adm1-v3"
      },
      "boundaries-adm2": {
        "type": "vector",
        "url": "mapbox://mapbox.boundaries-adm2-v3"
      }
    },
    "sprite": "mapbox://sprites/mapbox/basic-v8",
    "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
    "layers": [
      {
        "id": "background",
        "type": "background",
        "paint": {
          "background-color": "#f0f2f5"
        }
      },
      {
        "id": "land",
        "type": "fill",
        "source": "mapbox-streets",
        "source-layer": "land",
        "paint": {
          "fill-color": "#e5e7eb"
        }
      },
      {
        "id": "water",
        "type": "fill",
        "source": "mapbox-streets",
        "source-layer": "water",
        "paint": {
          "fill-color": "#9ca3af"
        }
      },
      {
        "id": "province-fill",
        "type": "fill",
        "source": "boundaries-adm1",
        "source-layer": "boundaries_admin_1",
        "filter": ["==", ["get", "iso_3166_1"], "ZA"],
        "paint": {
          "fill-color": "#d1d5db",
          "fill-opacity": 0.4,
          "fill-outline-color": "#374151"
        }
      },
      {
        "id": "province-border",
        "type": "line",
        "source": "boundaries-adm1",
        "source-layer": "boundaries_admin_1",
        "filter": ["==", ["get", "iso_3166_1"], "ZA"],
        "paint": {
          "line-color": "#1f2937",
          "line-width": 2,
          "line-opacity": 0.9
        }
      },
      {
        "id": "ward-fill",
        "type": "fill",
        "source": "boundaries-adm2",
        "source-layer": "boundaries_admin_2",
        "filter": ["==", ["get", "iso_3166_1"], "ZA"],
        "paint": {
          "fill-color": "#e5e7eb",
          "fill-opacity": 0.25,
          "fill-outline-color": "#9ca3af"
        }
      },
      {
        "id": "ward-border",
        "type": "line",
        "source": "boundaries-adm2",
        "source-layer": "boundaries_admin_2",
        "filter": ["==", ["get", "iso_3166_1"], "ZA"],
        "paint": {
          "line-color": "#6b7280",
          "line-width": 1,
          "line-opacity": 0.6,
          "line-dasharray": [2, 2]
        }
      },
      {
        "id": "province-label",
        "type": "symbol",
        "source": "boundaries-adm1",
        "source-layer": "boundaries_admin_1",
        "filter": ["==", ["get", "iso_3166_1"], "ZA"],
        "layout": {
          "text-field": "{name_en}",
          "text-font": ["Open Sans Semibold", "Arial Unicode MS Bold"],
          "text-size": 12,
          "text-transform": "uppercase",
          "text-letter-spacing": 0.1,
          "text-max-width": 8,
          "text-justify": "center",
          "symbol-placement": "point",
          "symbol-z-order": "auto"
        },
        "paint": {
          "text-color": "#111827",
          "text-halo-color": "#f9fafb",
          "text-halo-width": 1.5,
          "text-halo-blur": 0.5,
          "text-opacity": 0.9
        }
      }
    ],
    "light": {
      "anchor": "viewport",
      "color": "white",
      "intensity": 0.5
    }
  }